{
  "name": "grove",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "pnpm --filter hono dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down --volumes --remove-orphans"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "turbo": "^2.5.4",
    "typescript": "^5"
  }
}
